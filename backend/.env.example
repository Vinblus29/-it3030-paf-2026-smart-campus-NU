# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/smartcampus
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_256_bits
JWT_EXPIRATION=3600000

# Email Configuration (Gmail SMTP)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# AWS S3 Configuration
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=eu-north-1
AWS_S3_BUCKET=your_bucket_name

# AWS SNS Configuration (Push Notifications)
AWS_SNS_PLATFORM_ARN=arn:aws:sns:eu-north-1:713110441559:app/GCM/smartuni

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft OAuth2 Configuration
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# OAuth2 Redirect URL
APP_OAUTH2_REDIRECT_BASE_URL=http://localhost:5173

# ─── Push Notifications (AWS SNS + Firebase FCM) ───────────────────────────
# AWS SNS Platform Application ARN (Firebase/GCM platform app in SNS console)
# Already hardcoded in PushNotificationService:
#   arn:aws:sns:eu-north-1:713110441559:app/GCM/smartuni
# AWS credentials above (AWS_ACCESS_KEY / AWS_SECRET_KEY) are reused for SNS.
